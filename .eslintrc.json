{
  "env": {
    "node": true,
    "jest": true,
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "globals": {
    "DOMPurify": "readonly",
    "AppState": "readonly",
    "tailwind": "readonly",
    "THREE": "readonly"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-console": "off",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error",
    "no-throw-literal": "error"
  }
}
