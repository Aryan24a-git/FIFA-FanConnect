# FIFA FanConnect Environment Variables

# =========================================================================
# Option A: Standard Google Gemini API Key
# =========================================================================
# Obtained from Google AI Studio (starts with 'AIzaSy...')
GEMINI_API_KEY=your_actual_api_key_here

# =========================================================================
# Option B: OpenRouter API Key (Alternative for Free Gemma 2/4 Access)
# =========================================================================
# If you prefer to use OpenRouter (starts with 'sk-or-...'), paste it below:
# GEMINI_API_KEY=sk-or-v1-...
#
# Define which OpenRouter model you wish to use (defaults to 'google/gemma-2-9b-it:free' if omitted)
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# =========================================================================
# Option C: Groq API Key (Alternative for Free/Fast Gemma 2 Access)
# =========================================================================
# If you prefer to use Groq (starts with 'gsk_...'), paste it below:
# GEMINI_API_KEY=gsk_...
#
# Define which Groq model you wish to use (defaults to 'gemma2-9b-it' if omitted)
# GROQ_MODEL=gemma2-9b-it

# The port to run the Express server on
PORT=8080
